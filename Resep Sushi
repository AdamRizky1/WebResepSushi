    <div id="section-bahan" style="text-align: center; margin: 40px 0 20px; padding: 0 40px;">
      <p style="font-family: 'Georgia', serif; font-size: 28px; font-weight: bold; display: inline-block; background-color: rgba(0,0,0,0.6); color: white; padding: 10px 40px; border-radius: 8px; letter-spacing: 4px;">BAHAN</p>
      <table style="border-collapse: collapse; width: 100%;">
        <tr>
          <td style="border: 0; padding: 20px; width: 33%;">
            <img src="img/Nori.jpeg" style="width: 100%; max-width: 300px; height: 220px; object-fit: contain;"><br>
