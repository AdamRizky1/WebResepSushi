<!DOCTYPE html>
<html>
  <head>
    <style>
      html {
        scroll-behavior: smooth;
      }
      body {
        background-image: url('img/paper japan.jpg');
        margin-top: 80px;
      }
      nav {
        display: flex;
        align-items: center;
        background-image: url('img/kayu.jpg');
        padding: 20px 20px;
        gap: 8px;
        justify-content: space-evenly;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
        box-sizing: border-box;
      }
      nav a {                        
        color: white;
        text-decoration: none;
        background-color: rgba(0,0,0,0.5);
        padding: 10px 20px;
        font-weight: bold;
        font-family: 'Georgia', serif;
      }
      .logo {
        color: white;
        font-weight: bold;
        font-family: 'Georgia', serif;
        font-size: 20px;
        margin-right: auto; 
      }
      .container {
        position: relative;
        display: inline-block;
        margin-top: 10px;
        width: 1520px;
        height: 620px;
        overflow: hidden;
      }
      .kotak {
        position: absolute;
        cursor: pointer;
        transition: filter 0.4s;
      }
      .tanda-tanya {
        position: absolute;
        top: -35px;
        left: 45%;
        transform: translateX(-50%);
        color: white;
        font-size: 28px;
      }
      .keterangan {
        display: none;
        position: absolute;
        top: 10px;
        left: 45%;
        transform: translateX(-50%);
        background: rgba(0,0,0,0.8);
        color: white;
        padding: 8px 16px;
        border-radius: 8px;
        white-space: nowrap;
        font-family: 'Georgia', serif;
        font-size: 16px;
        z-index: 10;
      }
      .gelap {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: rgba(0,0,0,0);
        transition: background 0.4s;
        pointer-events: none;
      }
      .kotak:hover img {
        filter: brightness(2) drop-shadow(0 0 50px gold);
      }
      .kotak:hover .tanda-tanya {
        display: none;
      }
      .kotak:hover .keterangan {
        display: block;
      }
      .kotak:nth-child(2):hover ~ .gelap {
        background: radial-gradient(ellipse 620px 380px at 440px 300px, transparent 40%, rgba(0,0,0,0.8) 70%);
      }
      .kotak:nth-child(3):hover ~ .gelap {
        background: radial-gradient(ellipse 620px 380px at 1120px 300px, transparent 40%, rgba(0,0,0,0.8) 70%);
      }
      #home, #section-alat, #section-bahan, #section-langkah {
        scroll-margin-top: 80px;
      }
    </style>
  </head>
